# Pix Live — variáveis de ambiente (copie para .env; NUNCA comite .env)
# Todos os segredos ficam em env/secret group do host (Render), nunca no repo.

# Ambiente
NODE_ENV=development
API_PORT=3000

# Banco (Postgres). Em local, o docker-compose provê este valor.
DATABASE_URL=postgresql://pixlive:pixlive@localhost:5432/pixlive?schema=public

# Provedor de pagamento: "mock" roda 100% offline; "mercadopago" usa o sandbox.
PAYMENT_PROVIDER=mock

# Mercado Pago (sandbox) — só necessário quando PAYMENT_PROVIDER=mercadopago
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# Token de demonstração das rotas /admin (NÃO é segredo — rotulado na UI).
DEMO_ADMIN_TOKEN=demo-nao-secreto

# URL pública da API (para o webhook do MP apontar de volta)
PUBLIC_API_URL=http://localhost:3000
