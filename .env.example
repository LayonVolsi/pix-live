# Pix Live — variáveis de ambiente (copie para .env; NUNCA comite .env)
# Todos os segredos ficam em env/secret group do host (Render), nunca no repo.
# O boot valida tudo isto com Zod (fail-fast) — ver apps/api/src/config/env.config.ts.

# Ambiente
NODE_ENV=development
PORT=3000

# Banco (Postgres). Em local, o docker-compose provê este valor.
DATABASE_URL=postgresql://pixlive:pixlive@localhost:5432/pixlive?schema=public

# Provedor de pagamento: "mock" roda 100% offline; "mercadopago" usa o sandbox.
# (mock é proibido em produção — trava de segurança no schema de env.)
PAYMENT_PROVIDER=mock

# Segredo do webhook (verificação HMAC). Obrigatório em qualquer modo (o simular
# do admin assina com ele e o webhook verifica). Mínimo 16 chars. Troque em produção.
MP_WEBHOOK_SECRET=troque-este-segredo-de-dev-1234

# Token de demonstração das rotas /admin (NÃO é segredo — a UI rotula como público).
# Mínimo 8 chars. Só evita clique acidental de bot; o rate-limit é a defesa real.
DEMO_TOKEN=demo-nao-secreto

# Mercado Pago (sandbox) — só necessário quando PAYMENT_PROVIDER=mercadopago (fase 4).
# MP_ACCESS_TOKEN=
