{
  "name": "@pix-live/api",
  "version": "0.0.0",
  "private": true,
  "description": "API NestJS do Pix Live: webhook Pix assinado, idempotência e conciliação. O domínio puro vem de @pix-live/core.",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts"
  },
  "license": "MIT",
  "dependencies": {
    "@nestjs/common": "^10",
    "@nestjs/config": "^3",
    "@nestjs/core": "^10",
    "@nestjs/platform-express": "^10",
    "@nestjs/swagger": "^7",
    "@nestjs/terminus": "^10",
    "@nestjs/throttler": "^6",
    "@pix-live/core": "workspace:^",
    "@prisma/client": "^6",
    "helmet": "^8",
    "nestjs-pino": "^4",
    "pino": "^9",
    "pino-http": "^10",
    "qrcode": "^1",
    "reflect-metadata": "^0.2",
    "rxjs": "^7",
    "zod": "^3"
  },
  "devDependencies": {
    "@nestjs/testing": "^10",
    "@types/express": "^4",
    "@types/qrcode": "^1",
    "@types/supertest": "^6",
    "pino-pretty": "^13",
    "prisma": "^6",
    "supertest": "^7",
    "tsx": "^4"
  }
